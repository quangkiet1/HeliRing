# VITE_GEMINI_API_KEY: Optional. Enables live Gemini replies in the chatbot.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Gmail SMTP settings for /api/subscribe.
# Use a Google App Password, not your normal Gmail password.
GMAIL_USER="your-gmail@gmail.com"
GMAIL_APP_PASSWORD="your-16-character-app-password"

# Optional owner notification and email content settings.
DISCOUNT_EMAIL_TO="your-gmail@gmail.com"
DISCOUNT_CODE="HELIRING25"
DISCOUNT_SENDER_NAME="HELICORP"
PUBLIC_SITE_URL="https://your-domain.vercel.app"
